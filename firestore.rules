rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all deny rule for absolute safety
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Profiles ---
    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['id', 'username', 'full_name'])
        && request.resource.data.id == userId
        && request.resource.data.username is string && request.resource.data.username.size() >= 3 && request.resource.data.username.size() <= 40
        && request.resource.data.full_name is string && request.resource.data.full_name.size() <= 100;
      allow update: if isOwner(userId)
        && request.resource.data.id == userId
        && (!request.resource.data.keys().hasAny(['created_at']) || request.resource.data.created_at == resource.data.created_at)
        && request.resource.data.username is string 
        && request.resource.data.full_name is string;
      allow delete: if false; // Profiles cannot be self-deleted to maintain platform continuity
    }

    // --- Platforms ---
    match /platforms/{platformId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() 
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.keys().hasAll(['id', 'user_id', 'name'])
        && request.resource.data.name is string && request.resource.data.name.size() <= 100;
      allow update: if isSignedIn() && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.name is string;
      allow delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // --- Passwords ---
    match /passwords/{passwordId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() 
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.keys().hasAll(['id', 'user_id', 'account_name', 'password_levels'])
        && request.resource.data.account_name is string && request.resource.data.account_name.size() <= 150;
      allow update: if isSignedIn() && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.account_name is string;
      allow delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // --- Telegram Configurations ---
    match /telegram_configs/{configId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() 
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.keys().hasAll(['id', 'user_id']);
      allow update: if isSignedIn() && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }
  }
}
